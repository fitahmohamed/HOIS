<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── List columns (inline optional columns in the SO order lines tab) ── -->
    <record id="view_order_form_inherit_labor_line_totals" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.labor.line.totals</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Enable open-record icon so each line can be opened in the detail form -->
            <xpath expr="//field[@name='order_line']/list" position="attributes">
                <attribute name="open_form_view">True</attribute>
            </xpath>
            <!-- Optional columns after price_unit -->
            <xpath expr="//field[@name='order_line']/list/field[@name='price_unit']" position="after">
                <field name="x_basic_salary" string="FIN - Basic" optional="hide" groups="sales_team.group_sale_manager"/>
                <field name="x_housing_allowance" string="FIN - Housing" optional="hide" groups="sales_team.group_sale_manager"/>
                <field name="x_transport_allowance" string="FIN - Transport" optional="hide" groups="sales_team.group_sale_manager"/>
                <field name="x_food_allowance" string="FIN - Food" optional="hide" groups="sales_team.group_sale_manager"/>
                <field name="x_job_name" string="HR - Job" optional="hide" groups="base.group_user"/>
                <field name="x_nationality" string="HR - Nationality" optional="hide" groups="base.group_user"/>
                <field name="x_contract_type" string="HR - Contract Type" optional="hide" groups="base.group_user"/>
                <field name="x_working_hours" string="HR - Working Hours" optional="hide" groups="base.group_user"/>
                <field name="x_labor_rules_config_id" string="OPS - Rules Config" optional="hide" groups="sales_team.group_sale_manager"/>
                <field name="x_iqama_fee" string="OPS - Iqama" readonly="1" optional="hide" groups="base.group_user"/>
                <field name="x_work_permit_fee" string="OPS - Work Permit" readonly="1" optional="hide" groups="base.group_user"/>
                <field name="x_visa_or_transfer_fee" string="OPS - Visa/Transfer" readonly="1" optional="hide" groups="base.group_user"/>
                <field name="x_medical_insurance_fee" string="OPS - Medical Insurance" readonly="1" optional="hide" groups="base.group_user"/>
                <field name="x_total_salary" string="FIN - Total Salary" readonly="1" optional="show" groups="base.group_user"/>
                <field name="x_gosi_amount" string="FIN - GOSI" readonly="1" optional="show" groups="base.group_user"/>
                <field name="x_government_fees_total" string="OPS - Gov Fees" readonly="1" optional="show" groups="base.group_user"/>
                <field name="x_vacation_accrual_monthly" string="FIN - Vacation Accrual" readonly="1" optional="hide" groups="sales_team.group_sale_manager"/>
                <field name="x_eos_accrual_monthly" string="FIN - EOS Accrual" readonly="1" optional="hide" groups="sales_team.group_sale_manager"/>
                <field name="x_air_ticket_accrual_monthly" string="FIN - Ticket Accrual" optional="hide" groups="sales_team.group_sale_manager"/>
                <field name="x_total_service_cost" string="OPS - Total Service Cost" readonly="1" optional="show" groups="base.group_user"/>
            </xpath>
        </field>
    </record>

    <!-- ── Line detail popup form: tabbed Labor breakdown ── -->
    <record id="view_sale_order_line_form_labor_tabs" model="ir.ui.view">
        <field name="name">sale.order.line.form.labor.tabs</field>
        <field name="model">sale.order.line</field>
        <field name="inherit_id" ref="sale.sale_order_line_view_form_readonly"/>
        <field name="arch" type="xml">
            <!-- Append notebook after the last field in the readonly form -->
            <xpath expr="//field[@name='currency_id']" position="after">
                <notebook>
                    <page string="Financial" name="labor_financial" groups="sales_team.group_sale_manager">
                        <group>
                            <group string="Salary Components">
                                <field name="x_basic_salary"/>
                                <field name="x_housing_allowance"/>
                                <field name="x_transport_allowance"/>
                                <field name="x_food_allowance"/>
                            </group>
                            <group string="Totals">
                                <field name="x_total_salary"/>
                                <field name="x_gosi_amount"/>
                            </group>
                        </group>
                        <group>
                            <group string="Monthly Accruals (Provisions)">
                                <field name="x_vacation_accrual_monthly" string="Vacation Accrual"/>
                                <field name="x_eos_accrual_monthly" string="EOS Accrual"/>
                                <field name="x_air_ticket_accrual_monthly" string="Air Ticket Accrual"/>
                            </group>
                        </group>
                    </page>
                    <page string="HR Details" name="labor_hr">
                        <group>
                            <field name="x_job_name" string="Job Title"/>
                            <field name="x_nationality" string="Nationality"/>
                            <field name="x_contract_type" string="Contract Type"/>
                            <field name="x_working_hours" string="Working Hours"/>
                        </group>
                    </page>
                    <page string="Operations" name="labor_ops">
                        <group>
                            <group string="Rules Config" groups="sales_team.group_sale_manager">
                                <field name="x_labor_rules_config_id" string="Rules Config"/>
                            </group>
                            <group string="Government Fees">
                                <field name="x_iqama_fee" string="Iqama Fee"/>
                                <field name="x_work_permit_fee" string="Work Permit"/>
                                <field name="x_visa_or_transfer_fee" string="Visa / Transfer"/>
                                <field name="x_medical_insurance_fee" string="Medical Insurance"/>
                            </group>
                        </group>
                        <group>
                            <group string="Totals">
                                <field name="x_government_fees_total" string="Total Gov Fees"/>
                                <field name="x_total_service_cost" string="Total Service Cost"/>
                            </group>
                        </group>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>
</odoo>
