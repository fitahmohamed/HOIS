        <field name="name">Labor</field>
        <field name="parent_id" ref="product.product_category_all"/>
    </record>

    <record id="categ_labor_engineering" model="product.category">
        <field name="name">Labor - Engineering</field>
        <field name="parent_id" ref="categ_labor_parent"/>
    </record>

    <record id="categ_labor_technical" model="product.category">
        <field name="name">Labor - Technical</field>
        <field name="parent_id" ref="categ_labor_parent"/>
    </record>

    <record id="categ_labor_operations" model="product.category">
        <field name="name">Labor - Operations</field>
        <field name="parent_id" ref="categ_labor_parent"/>
    </record>

    <record id="categ_labor_hse" model="product.category">
        <field name="name">Labor - HSE</field>
        <field name="parent_id" ref="categ_labor_parent"/>
