        <field name="name">Al Futtaim Facilities</field>
        <field name="country_id" ref="base.sa"/>
        <field name="customer_rank">1</field>
        <field name="is_company" eval="True"/>
    </record>

    <record id="partner_demo_aramco" model="res.partner">
        <field name="name">Saudi Aramco Facilities</field>
        <field name="country_id" ref="base.sa"/>
        <field name="customer_rank">1</field>
        <field name="is_company" eval="True"/>
