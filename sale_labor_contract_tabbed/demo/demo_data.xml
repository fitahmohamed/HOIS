    <record id="user_demo_hr" model="res.users">
        <field name="name">Demo HR User</field>
        <field name="login">demo.hr@demo.local</field>
        <field name="password">demo1234</field>
        <field name="group_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Sales Manager — full access to all tabs, menus, salary fields -->
