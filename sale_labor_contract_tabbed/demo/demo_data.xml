<?xml version="1.0" encoding="utf-8"?>
<!--
    Demo data for sale_labor_contract_tabbed.

    Loaded automatically only when the module is installed with the load-demo flag:
        python odoo-bin -i sale_labor_contract_tabbed -load-demo -c ...

    For local environments already seeded via Python scripts (demo/scripts/step_*.py),
    this file is NEVER loaded because -u (upgrade) does not trigger demo data.

    noupdate=1 : Odoo will not overwrite these records on subsequent upgrades.
-->
